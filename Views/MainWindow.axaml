<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MedStation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MedStation.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="MedStation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        >
        
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:MainMenuWindowViewModel}">
            <views:MainMenuWindow/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:AdminPanelWindowViewModel}">
            <views:AdminPanelWindow/> 
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:EmployeePanelWindowViewModel}">
            <views:EmployeePanelWindow/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:PatientPanelWindowViewModel}">
            <views:PatientPanelWindow/>
        </DataTemplate>
    </Window.DataTemplates>
    
    
    <ContentControl Content="{Binding CurrentView}"/>
        
        
</Window>
